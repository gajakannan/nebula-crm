info: Microsoft.EntityFrameworkCore.Database.Command[20101]
      Executed DbCommand (4ms) [Parameters=[@status='?', @windowStart='?' (DbType = DateTime)], CommandType='Text', CommandTimeout='30']
      SELECT p0."Name", count(*)::int
      FROM "Submissions" AS s
      LEFT JOIN (
          SELECT p."Id", p."Name"
          FROM "Programs" AS p
          WHERE NOT (p."IsDeleted")
      ) AS p0 ON s."ProgramId" = p0."Id"
