{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nebula.local/schemas/renewal.schema.json",
  "title": "Renewal",
  "description": "Renewal workflow entity response contract.",
  "type": "object",
  "required": [
    "id",
    "accountId",
    "brokerId",
    "currentStatus",
    "renewalDate",
    "assignedTo",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "accountId": {
      "type": "string",
      "format": "uuid"
    },
    "brokerId": {
      "type": "string",
      "format": "uuid"
    },
    "submissionId": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "lineOfBusiness": {
      "anyOf": [
        { "$ref": "https://nebula.local/schemas/line-of-business.schema.json" },
        { "type": "null" }
      ]
    },
    "currentStatus": {
      "type": "string"
    },
    "renewalDate": {
      "type": "string",
      "format": "date"
    },
    "assignedTo": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdBy": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedBy": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    }
  },
  "additionalProperties": false
}
